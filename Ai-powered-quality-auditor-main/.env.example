# ==================== API CONFIGURATION ====================
API_PORT=8000
API_RELOAD=true
API_HOST=0.0.0.0

# ==================== LLM CONFIGURATION ====================
# Groq API credentials
GROQ_API_KEY=your_groq_api_key_here

# LLM Model selection
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ==================== RAG & VECTOR DATABASE ====================
# Pinecone configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX_NAME=compliance-policies
PINECONE_EMBEDDING_DIMENSION=384

# Ollama local LLM (for offline use)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# ==================== TRANSCRIPTION ====================
# Whisper configuration
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
# Options: tiny, base, small, medium, large

# Language detection
AUTO_TRANSLATE=true
TARGET_LANGUAGE=en

# ==================== PII MASKING ====================
ENABLE_PII_MASKING=true
ENABLE_NER=true
SPACY_MODEL=en_core_web_sm
# Should be installed with: python -m spacy download en_core_web_sm

# ==================== STORAGE & DATABASE ====================
# File storage
DATA_STORAGE_PATH=./data
TEMP_UPLOAD_PATH=./temp

# Redis cache (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== AUDIT SERVICE ====================
AUDIT_ENABLE_LLM=true
AUDIT_SCORING_INTERVAL=10.0
AUDIT_ANOMALY_SENSITIVITY=2.0

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=./logs/auditor.log
LOG_FORMAT=json
# Options: json, text

# ==================== DEVELOPMENT ====================
DEBUG=false
ENVIRONMENT=production
# Options: development, staging, production

# ==================== MONITORING ====================
ENABLE_MONITORING=true
MONITORING_PORT=9090
METRICS_EXPORT_INTERVAL=60
